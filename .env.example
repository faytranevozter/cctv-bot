TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234gh
SUPERUSER_IDS=123456789

# Optional bootstrap list. Runtime approvals are stored in DB_FILE.
# AUTHORIZED_CHAT_IDS=123456789,-1001234567890

# SQLite database file. Default: ./cctv_bot.db
# In Docker the image sets this to /data/cctv_bot.db (mount a volume).
# DB_FILE=cctv_bot.db

# Manage cameras at runtime via Telegram:
#   /addcam "Kantor Kiri" rtsp://user:pass@host/stream
#   /delcam "Kantor Kiri"
#   /cameras

# Legacy CAMERA_N_NAME / CAMERA_N_URL env vars are still recognized for
# one-shot migration into the SQLite database when no cameras exist.
# CAMERA_1_NAME=GudangDepan
# CAMERA_1_URL=rtmp://192.168.1.10/live/cam1

# Optional, defaults shown
# FFMPEG_BIN=ffmpeg
# FFMPEG_TIMEOUT_SEC=15
# MAX_CONCURRENT_CAPTURES=3
