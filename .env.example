TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234gh
SUPERUSER_IDS=123456789

# Optional bootstrap list. Runtime approvals are stored in AUTH_FILE.
# AUTHORIZED_CHAT_IDS=123456789,-1001234567890

# Authorization state file. Default: ./authorized_chats.json
# AUTH_FILE=authorized_chats.json

# Cameras are persisted in a JSON file. Default: ./cameras.json
# In Docker the image sets this to /data/cameras.json (mount a volume).
# CAMERAS_FILE=cameras.json

# Manage cameras at runtime via Telegram:
#   /addcam "Kantor Kiri" rtsp://user:pass@host/stream
#   /delcam "Kantor Kiri"
#   /cameras
# Or edit cameras.json directly (JSON array of {"name","url"}).

# Legacy CAMERA_N_NAME / CAMERA_N_URL env vars are still recognized
# for one-shot migration into cameras.json on first run, then ignored.
# CAMERA_1_NAME=GudangDepan
# CAMERA_1_URL=rtmp://192.168.1.10/live/cam1

# Optional, defaults shown
# FFMPEG_BIN=ffmpeg
# FFMPEG_TIMEOUT_SEC=15
# MAX_CONCURRENT_CAPTURES=3
